# =============================================================================
# YouTube Automation – Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# ----------------------------------------------------------------------------
# Supabase (required)
# Get these from: https://supabase.com → Project Settings → API
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=videos

# ----------------------------------------------------------------------------
# OpenAI (required for script generation and TTS)
# Get your key from: https://platform.openai.com/api-keys
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Optional: use a stored OpenAI Prompt for script generation
# OPENAI_PROMPT_ID=
# OPENAI_PROMPT_VERSION=1

# ----------------------------------------------------------------------------
# fal.ai (required for AI image generation)
# Get your key from: https://fal.ai/dashboard/keys
# ----------------------------------------------------------------------------
FAL_KEY=...

# ----------------------------------------------------------------------------
# YouTube OAuth (required for YouTube uploads)
# Set up at: https://console.cloud.google.com → Credentials → OAuth 2.0
# Enable the YouTube Data API v3.
# Authorised redirect URIs must include:
#   http://localhost:3000/api/auth/youtube/callback  (development)
#   https://your-domain.com/api/auth/youtube/callback  (production)
# ----------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# Base URL of this application (no trailing slash)
# Use http://localhost:3000 for local development.
NEXTAUTH_URL=https://your-domain.com

# Optionally upload VTT captions when uploading to YouTube (default: true)
# ENABLE_YOUTUBE_CAPTIONS=true

# ----------------------------------------------------------------------------
# Cron jobs (required if using /api/cron/upload)
# Set a long random string – Vercel Cron sends it as Bearer token.
# ----------------------------------------------------------------------------
CRON_SECRET=your_secure_random_string

# ----------------------------------------------------------------------------
# X (Twitter) API – optional, enables X-Trends and X-Agent features
# Bearer token for read-only search (x-trends endpoint):
# X_BEARER_TOKEN=your_x_bearer_token
#
# OAuth 1.0a credentials for the x-agent endpoint (advanced search):
# X_CONSUMER_KEY=your_x_consumer_key
# X_CONSUMER_SECRET=your_x_consumer_secret
# X_ACCESS_TOKEN=your_x_access_token
# X_ACCESS_TOKEN_SECRET=your_x_access_token_secret
# X_TREND_QUERY=lang:en -is:retweet -is:reply
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# ElevenLabs – optional, higher quality TTS
# Get your key from: https://elevenlabs.io
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Video assembly backend – required only if assembling videos server-side
#
# If you are deploying on Vercel (no FFmpeg), point VIDEO_ASSEMBLY_URL to a
# separate backend (e.g. the FastAPI service in /api) that has FFmpeg installed.
# If VIDEO_ASSEMBLY_URL is not set, Next.js will try to run FFmpeg locally.
#
# FASTAPI_URL=https://your-backend.com        # also used as fallback
# NEXT_PUBLIC_API_URL=https://your-backend.com
# VIDEO_ASSEMBLY_URL=https://your-backend.com/api/assemble-video
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Optional branding & background music
# Use either a URL (fetched at assembly time) or a local path.
# BACKGROUND_MUSIC_URL=https://your-cdn.com/music.mp3
# BACKGROUND_MUSIC_PATH=./public/audio/background.mp3
# BACKGROUND_MUSIC_VOLUME=0.2
# BRANDING_LOGO_URL=https://your-cdn.com/logo.png
# BRANDING_LOGO_PATH=./public/placeholder-logo.png
# BRANDING_LOGO_SCALE=0.12
# BRANDING_LOGO_OPACITY=0.85
# BRANDING_LOGO_POSITION=top-right   # top-left | top-right | bottom-left | bottom-right
# BRANDING_LOGO_PADDING=24
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Stripe – optional, enables subscription / billing features
# STRIPE_PRICE_ID_PRO=price_xxx
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# FastAPI backend (Python) – only needed when running the FastAPI service
# DATABASE_URL=postgresql://user:password@host:5432/video_db
# REDIS_URL=redis://localhost:6379
# ----------------------------------------------------------------------------
