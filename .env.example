# Frontend + Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=videos

# App URLs
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
FASTAPI_URL=http://localhost:8000
VIDEO_ASSEMBLY_URL=

# Content generation
OPENAI_API_KEY=sk-your-openai-key
OPENAI_PROMPT_ID=
OPENAI_PROMPT_VERSION=1
FAL_KEY=your_fal_key
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
UNSPLASH_API_KEY=

# Audio generation
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# YouTube OAuth / uploads
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_ACCESS_TOKEN=
ENABLE_YOUTUBE_CAPTIONS=true

# Scheduled uploads
CRON_SECRET=replace-with-a-long-random-string

# X / Twitter integrations
X_BEARER_TOKEN=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_TREND_QUERY=

# Optional branding / assembly assets
BACKGROUND_MUSIC_URL=
BACKGROUND_MUSIC_PATH=./public/audio/background.mp3
BACKGROUND_MUSIC_VOLUME=0.2
BRANDING_LOGO_URL=
BRANDING_LOGO_PATH=./public/placeholder-logo.png
BRANDING_LOGO_SCALE=0.12
BRANDING_LOGO_OPACITY=0.85
BRANDING_LOGO_POSITION=top-right
BRANDING_LOGO_PADDING=24

# Worker / API infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_db
REDIS_URL=redis://localhost:6379
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=video_db
STORAGE_PATH=/app/storage/videos
STORAGE_PROVIDER=s3
DELETE_LOCAL_AFTER_UPLOAD=false
